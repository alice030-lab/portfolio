---
import Layout from "../layouts/Layout.astro";
import Mascot from "../components/Mascot.astro";
import Clouds from "../components/Clouds.astro";
import { works } from "../data/works";
const featured = works.slice(0, 4);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<Layout>
  <section class="pop-hero">
    <Clouds />
    <div class="pop-inner">
      <div>
        <div class="speech-bubble">哈囉，我是 Alice！</div>
        <div>
          <span class="sticker">Est. 2018</span>
          <span class="sticker red tilt-right">現正接案中</span>
        </div>
        <h1 class="pop-title">Alice<br/><em>Office</em></h1>
        <p class="pop-sub">一間在品牌識別、編輯設計、與產品介面之間跳來跳去的小工作室。做的東西要耐看，也要好玩。</p>
        <a href={`${base}/work`} class="pop-cta">看看作品 →</a>
        <div class="pop-meta">
          <div><strong>14</strong>品牌系統</div>
          <div><strong>06</strong>產品介面</div>
          <div><strong>2018</strong>創立至今</div>
        </div>
      </div>
      <div class="mascot-wrap">
        <Mascot size={340} />
      </div>
    </div>
  </section>

  <div class="pop-marquee">
    <div class="track">
      <span>品牌識別</span><span class="star">✦</span>
      <span>編輯設計</span><span class="star">✦</span>
      <span>包裝</span><span class="star">✦</span>
      <span>UI / UX</span><span class="star">✦</span>
      <span>社群內容</span><span class="star">✦</span>
      <span>插畫</span><span class="star">✦</span>
      <span>品牌識別</span><span class="star">✦</span>
      <span>編輯設計</span><span class="star">✦</span>
      <span>包裝</span><span class="star">✦</span>
      <span>UI / UX</span><span class="star">✦</span>
    </div>
  </div>

  <section class="container">
    <div class="section-head">
      <h2>精選作品</h2>
      <span class="num">— 01 / 索引</span>
    </div>
    <div class="featured">
      {featured.map((w, i) => (
        <a href={`${base}/work/${w.slug}`} class={`work-card reveal ${w.span ?? ""}`}>
          <div class="frame"><img src={w.cover} alt={w.title} loading={i === 0 ? "eager" : "lazy"} /></div>
          <div class="meta">
            <span class="tag">{w.tag}</span>
            <span class="title">{w.title}</span>
            <span class="year">{w.year}</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="container">
    <div class="section-head">
      <h2>服務項目</h2>
      <span class="num">— 02 / 服務</span>
    </div>
    <div class="services">
      {[
        { n: "01", name: "品牌識別", tags: "VI · 標準字 · 規範手冊" },
        { n: "02", name: "編輯與印刷設計", tags: "書籍 · DM · 操作手冊" },
        { n: "03", name: "包裝設計", tags: "結構 · 平面 · 系統" },
        { n: "04", name: "產品介面", tags: "UI · UX · 設計系統" },
        { n: "05", name: "內容系統", tags: "社群 · 模板 · 視覺指導" },
      ].map(s => (
        <div class="service-row reveal">
          <span class="num">{s.n}</span>
          <span class="name">{s.name}</span>
          <span class="tags">{s.tags}</span>
        </div>
      ))}
    </div>
  </section>
</Layout>
