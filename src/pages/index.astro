---
import Layout from "../layouts/Layout.astro";
import { categories } from "../data/gallery";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<Layout>
  <!-- 入場效果：滾動推門進入 -->
  <section class="entrance" id="entrance">
    <div class="entrance-stage">
      <div class="entrance-meta">
        <div class="entrance-eyebrow">— Welcome to —</div>
        <h2 class="entrance-title">Alice <em>Office</em></h2>
        <div class="entrance-arrow">
          <span class="arrow-text">向下捲動，門將打開</span>
          <svg class="arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 5 V 19 M 5 13 L 12 20 L 19 13"/></svg>
        </div>
      </div>

      <div class="box">
        <div class="box-body">
          <div class="box-interior">
            <div class="ed-hero-inner">
              <div>
                <div class="eyebrow" style="margin-bottom: 32px;">— Alice Office · Est. 2018 · Taipei</div>
                <h1>
                  設計<span class="reg">，</span><br/>
                  是一種思考<br/>
                  的<em>總和。</em>
                </h1>
                <p class="sub">Alice Office 是設計師吳芝淩的個人實踐 — 在品牌識別、編輯設計、與產品介面之間工作，服務認真對待細節的團隊。</p>
                <div class="cta-row">
                  <a href={`${base}/work`} class="btn-pill">看作品</a>
                  <a href={`${base}/contact`} class="btn-pill light">聊聊合作</a>
                </div>
              </div>
              <div class="hero-stack" id="hero-stack">
                <div class="blk b1 rose"><div class="tag">Identity</div><div class="num">01</div><div class="label">VI 規劃</div></div>
                <div class="blk b2 sage"><div class="tag">Print</div><div class="num">02</div><div class="label">DM & 平面</div></div>
                <div class="blk b3 lavender"><div class="tag">Editorial</div><div class="num">03</div><div class="label">說明書</div></div>
                <div class="blk b4 peach"><div class="tag">Package</div><div class="num">04</div></div>
                <div class="blk b5 cream"><div class="tag">UI / UX</div><div class="num">05</div></div>
                <div class="blk b6 rose-deep"><div class="tag">Social</div><div class="num">06</div></div>
                <button type="button" class="stack-reset" id="stack-reset" aria-label="重新整理想法">↺ 重新整理想法</button>
                <div class="stack-hint">↑ 試著拖拉看看</div>
              </div>
            </div>
          </div>
        </div>
        <div class="box-lid">
          <div class="box-lid-tag">Alice Office</div>
        </div>
      </div>
    </div>
  </section>

  <section class="container expertise">
    <div class="section-head">
      <div>
        <div class="eyebrow">Skills</div>
        <h2>擅長<em>什麼</em></h2>
      </div>
      <span class="num">— 01</span>
    </div>
    <div class="expertise-grid">
      <div class="exp-tile reveal">
        <div class="exp-num">01</div>
        <h3>VI 規劃 & 主視覺</h3>
        <p>標準字、識別系統、年度主視覺、活動延伸應用。從 logo 到整套品牌資產一次到位。</p>
      </div>
      <div class="exp-tile reveal">
        <div class="exp-num">02</div>
        <h3>DM & 平面設計</h3>
        <p>DM 改版、宣傳單張、Banner、海報。專門處理資訊量大、要在小篇幅內說清楚的案子。</p>
      </div>
      <div class="exp-tile reveal">
        <div class="exp-num">03</div>
        <h3>說明書與編輯設計</h3>
        <p>長篇資訊的分層、圖示重繪、閱讀動線。讓厚手冊也能被讀完。</p>
      </div>
      <div class="exp-tile reveal">
        <div class="exp-num">04</div>
        <h3>包裝設計</h3>
        <p>從結構、平面到插畫一次完成的包裝系列。擅長處理在地品牌、文創、農特產。</p>
      </div>
      <div class="exp-tile reveal">
        <div class="exp-num">05</div>
        <h3>UI / UX 設計</h3>
        <p>訂位系統、營運後台、會員介面。不只是美，更要好用、能解決真的問題。</p>
      </div>
      <div class="exp-tile reveal">
        <div class="exp-num">06</div>
        <h3>社群內容</h3>
        <p>貼文模板系統、節慶活動圖、品牌日常內容。建一套工具讓團隊能持續產出。</p>
      </div>
    </div>
  </section>

  <section class="container track-record">
    <div class="section-head">
      <div>
        <div class="eyebrow">Clients</div>
        <h2>合作過的<em>客戶</em></h2>
      </div>
      <span class="num">— 02</span>
    </div>
    <div class="client-types reveal">
      <div class="eyebrow" style="margin-bottom: 14px;">服務過的客戶類型</div>
      <p>地方社區發展協會 · 製造業集團 · 私人會員制俱樂部 · 電動車充電網營運商 · 食品與農特產品牌 · 生活風格品牌 · 文化展覽機構</p>
    </div>
  </section>

  <section class="container why">
    <div class="section-head">
      <div>
        <div class="eyebrow">Why me</div>
        <h2>為何選擇<em>我</em></h2>
      </div>
      <span class="num">— 03</span>
    </div>
    <div class="why-grid">
      <article class="why-tile">
        <div class="why-num">01</div>
        <h3>會寫前端</h3>
        <p>設計圖不只交給工程師看 — 還能自己做出來。少了交接成本，畫面落地誤差最小，動效細節真的會被實作。</p>
      </article>
      <article class="why-tile">
        <div class="why-num">02</div>
        <h3>有美感</h3>
        <p>多年品牌設計沉澱，從版面、字型、配色到留白都不輕率。不模板化，不套素材庫，每一張畫面都重新想過。</p>
      </article>
      <article class="why-tile">
        <div class="why-num">03</div>
        <h3>懂行銷</h3>
        <p>設計不只好看 — 還要能被找到、能說服、能轉換。理解目標受眾、SEO、文案結構、消費心理。</p>
      </article>
      <article class="why-tile">
        <div class="why-num">04</div>
        <h3>三合一在一個人身上</h3>
        <p>通常需要三人團隊（設計師 / 前端 / 行銷）才能整合的能力 — 在我這裡是一個人。溝通成本歸零，思考連貫。</p>
      </article>
    </div>
  </section>

  <section class="container pain">
    <div class="section-head">
      <div>
        <div class="eyebrow">Pain Points · AI 時代的競爭定位</div>
        <h2>我能解決的<em>痛點</em></h2>
      </div>
      <span class="num">— 04</span>
    </div>
    <p class="pain-intro">AI 出圖很快，但企業真正的痛點是「圖很多、能用的很少；好看的很多、有靈魂的很少」。<br/>點開卡片看 AI 解決不了什麼、我可以怎麼接手。</p>

    <div class="pain-grid">
      <div class="pain-card" data-flipped="false">
        <div class="pain-face pain-front">
          <div class="pain-num">01</div>
          <div class="pain-tag">AI 短處</div>
          <h3>品牌一致性 &<br/>系統化</h3>
          <p>AI 擅長「單張」驚艷的圖，但難維持跨情境一致 — Logo 極簡、Banner 跑風格。配色比例、字體規範、角色外型很難精確控制。</p>
          <button type="button" class="pain-flip-btn">看我怎麼解 →</button>
        </div>
        <div class="pain-face pain-back">
          <div class="pain-num">01</div>
          <div class="pain-tag pain-tag-light">我的解法</div>
          <h3>建立設計系統</h3>
          <ul>
            <li>定義精準的品牌規範、配色與元件</li>
            <li>跨平台整合：網頁 / APP / 印刷物一套到底</li>
            <li>讓品牌靈魂在每個載體都不散</li>
          </ul>
          <button type="button" class="pain-flip-btn">← 返回</button>
        </div>
      </div>

      <div class="pain-card" data-flipped="false">
        <div class="pain-face pain-front">
          <div class="pain-num">02</div>
          <div class="pain-tag">AI 短處</div>
          <h3>邏輯溝通 &<br/>策略思考</h3>
          <p>AI 只能依 Prompt 出圖，不理解「為什麼」。客戶說「想要大氣一點」AI 給華麗圖，但好設計要先問：受眾是誰？這張圖能增加轉化嗎？</p>
          <button type="button" class="pain-flip-btn">看我怎麼解 →</button>
        </div>
        <div class="pain-face pain-back">
          <div class="pain-num">02</div>
          <div class="pain-tag pain-tag-light">我的解法</div>
          <h3>視覺顧問 + UX 洞察</h3>
          <ul>
            <li>提供設計背後的策略支持</li>
            <li>站在使用者視角設計可用的產品（Usable）</li>
            <li>而不是好看但沒人用的圖庫</li>
          </ul>
          <button type="button" class="pain-flip-btn">← 返回</button>
        </div>
      </div>

      <div class="pain-card" data-flipped="false">
        <div class="pain-face pain-front">
          <div class="pain-num">03</div>
          <div class="pain-tag">AI 短處</div>
          <h3>精確修正 &<br/>工程落地</h3>
          <p>AI 生成的是像素圖，難微調、難工程對接。客戶想把按鈕往左移 2px，AI 會重畫一張完全不同的圖；產出非向量、非分層原檔，工程接不到。</p>
          <button type="button" class="pain-flip-btn">看我怎麼解 →</button>
        </div>
        <div class="pain-face pain-back">
          <div class="pain-num">03</div>
          <div class="pain-tag pain-tag-light">我的解法</div>
          <h3>精修 + 向量化</h3>
          <ul>
            <li>用前端經驗把 AI 創意「工程化」</li>
            <li>產出符合前端標準的 SVG / Figma 原檔</li>
            <li>4K 螢幕到名片都一樣清晰</li>
          </ul>
          <button type="button" class="pain-flip-btn">← 返回</button>
        </div>
      </div>

      <div class="pain-card" data-flipped="false">
        <div class="pain-face pain-front">
          <div class="pain-num">04</div>
          <div class="pain-tag">AI 短處</div>
          <h3>法律風險 &<br/>版權保障</h3>
          <p>AI 製圖存在嚴重的版權模糊地帶。多數國家法律不保護純 AI 生成物，企業視覺資產隨時可能被抄襲且無法維權。</p>
          <button type="button" class="pain-flip-btn">看我怎麼解 →</button>
        </div>
        <div class="pain-face pain-back">
          <div class="pain-num">04</div>
          <div class="pain-tag pain-tag-light">我的解法</div>
          <h3>原創保證 + AI 輔助</h3>
          <ul>
            <li>提供具備法律效力的原創設計</li>
            <li>用 AI 加速概念發想，但成品經人工重繪</li>
            <li>確保商業安全 + 完整版權歸屬</li>
          </ul>
          <button type="button" class="pain-flip-btn">← 返回</button>
        </div>
      </div>
    </div>

    <aside class="pain-killer">
      <div class="killer-eyebrow">— 我的殺手鐧</div>
      <h3>讓設計動起來，<em>解決真實問題</em></h3>
      <p><strong>AI 的輸出只是「素材」，我的產出是「成品」。</strong></p>
      <p>客戶有 AI 圖沒用 — 他需要有人把圖變成一個會動的 React 元件、一個有互動邏輯的介面、一個能用的 SaaS 產品。</p>
      <p class="killer-tagline">我把自己定位為「<em>能解決工程問題的設計策略家</em>」 — AI 是我的助手，不是競爭對手。</p>
    </aside>

    <script is:inline>
      (function () {
        document.querySelectorAll(".pain-flip-btn").forEach(btn => {
          btn.addEventListener("click", (e) => {
            const card = e.currentTarget.closest(".pain-card");
            if (!card) return;
            card.dataset.flipped = card.dataset.flipped === "true" ? "false" : "true";
          });
        });
      })();
    </script>
  </section>

  <section class="container">
    <div class="section-head">
      <div>
        <div class="eyebrow">Work</div>
        <h2>作品<em>分類</em></h2>
      </div>
      <span class="num">— 05</span>
    </div>

    <script is:inline>
      (function () {
        const entrance = document.getElementById("entrance");
        if (!entrance) return;
        const stage = entrance.querySelector(".entrance-stage");
        const update = () => {
          const r = entrance.getBoundingClientRect();
          const scrolled = -r.top;
          const total = entrance.offsetHeight - window.innerHeight;
          const p = Math.max(0, Math.min(1, scrolled / total));
          stage.style.setProperty("--open", p.toFixed(3));
        };
        window.addEventListener("scroll", update, { passive: true });
        window.addEventListener("resize", update);
        update();
      })();

      // Draggable hero blocks
      (function () {
        const stack = document.getElementById("hero-stack");
        if (!stack) return;
        const blocks = stack.querySelectorAll(".blk");
        const reset = document.getElementById("stack-reset");
        const state = new WeakMap();

        blocks.forEach((blk) => {
          state.set(blk, { x: 0, y: 0, rot: 0 });

          const apply = (dragging) => {
            const s = state.get(blk);
            const scale = dragging ? 1.06 : 1;
            blk.style.transform = `translate(${s.x}px, ${s.y}px) rotate(${s.rot}deg) scale(${scale})`;
          };

          let startX = 0, startY = 0, baseX = 0, baseY = 0;

          blk.addEventListener("pointerdown", (e) => {
            const s = state.get(blk);
            startX = e.clientX; startY = e.clientY;
            baseX = s.x; baseY = s.y;
            blk.classList.add("dragging", "has-moved");
            blk.setPointerCapture(e.pointerId);
            reset?.classList.add("show");
            apply(true);
          });

          blk.addEventListener("pointermove", (e) => {
            if (!blk.classList.contains("dragging")) return;
            const s = state.get(blk);
            s.x = baseX + (e.clientX - startX);
            s.y = baseY + (e.clientY - startY);
            s.rot = Math.max(-12, Math.min(12, ((e.clientX - startX) + (e.clientY - startY)) * 0.04));
            state.set(blk, s);
            apply(true);
          });

          const release = () => {
            if (!blk.classList.contains("dragging")) return;
            const s = state.get(blk);
            // settle slight rotation halved for a relaxed look
            s.rot = s.rot * 0.5;
            state.set(blk, s);
            blk.classList.remove("dragging");
            apply(false);
          };
          blk.addEventListener("pointerup", release);
          blk.addEventListener("pointercancel", release);
          blk.addEventListener("lostpointercapture", release);
        });

        reset?.addEventListener("click", () => {
          blocks.forEach((blk) => {
            state.set(blk, { x: 0, y: 0, rot: 0 });
            blk.classList.remove("dragging");
            blk.classList.remove("has-moved");
            blk.style.transform = "";
          });
          reset.classList.remove("show");
        });
      })();
    </script>
    <div class="category-list">
      {categories.map(c => {
        const count = c.subsections ? c.subsections.reduce((n, s) => n + s.images.length, 0) : (c.images?.length ?? 0);
        return (
          <a href={`${base}/work#${c.key}`} class="category-row reveal">
            <div class="cat-info">
              <h3>{c.name}</h3>
              <p>{c.desc}</p>
            </div>
            <div class="cat-count">{count} 件 →</div>
          </a>
        );
      })}
    </div>
  </section>
</Layout>
