---
import Layout from "../layouts/Layout.astro";
import { categories } from "../data/gallery";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<Layout>
  <!-- 入場效果：滾動推門進入 -->
  <section class="entrance" id="entrance">
    <div class="entrance-stage">
      <div class="entrance-meta">
        <div class="entrance-eyebrow">— Welcome to —</div>
        <h2 class="entrance-title">Alice <em>Office</em></h2>
        <div class="entrance-arrow">
          <span class="arrow-text">向下捲動，門將打開</span>
          <svg class="arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 5 V 19 M 5 13 L 12 20 L 19 13"/></svg>
        </div>
      </div>

      <div class="arch">
        <!-- 拱內：放真正的 Hero 內容，arch 變大時內容自然顯露 -->
        <div class="arch-interior">
          <div class="ed-hero-inner">
            <div>
              <div class="eyebrow" style="margin-bottom: 32px;">— Alice Office · Est. 2018 · Taipei</div>
              <h1>
                設計<span class="reg">，</span><br/>
                是一種思考<br/>
                的<em>總和。</em>
              </h1>
              <p class="sub">Alice Office 是設計師吳芝淩的個人實踐 — 在品牌識別、編輯設計、與產品介面之間工作，服務認真對待細節的團隊。</p>
              <div class="cta-row">
                <a href={`${base}/work`} class="btn-pill">看作品</a>
                <a href={`${base}/contact`} class="btn-pill light">聊聊合作</a>
              </div>
            </div>
            <div class="hero-stack">
              <div class="blk b1 rose"><div class="tag">Identity</div><div class="num">01</div><div class="label">VI 規劃</div></div>
              <div class="blk b2 sage"><div class="tag">Print</div><div class="num">02</div><div class="label">DM & 平面</div></div>
              <div class="blk b3 lavender"><div class="tag">Editorial</div><div class="num">03</div><div class="label">說明書</div></div>
              <div class="blk b4 peach"><div class="tag">Package</div><div class="num">04</div></div>
              <div class="blk b5 cream"><div class="tag">UI / UX</div><div class="num">05</div></div>
              <div class="blk b6 rose-deep"><div class="tag">Social</div><div class="num">06</div></div>
            </div>
          </div>
        </div>
        <!-- 兩片門 -->
        <div class="door door-l">
          <div class="door-panel"></div>
          <div class="door-handle"></div>
        </div>
        <div class="door door-r">
          <div class="door-panel"></div>
          <div class="door-handle"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="container expertise">
    <div class="section-head">
      <div>
        <div class="eyebrow">Skills</div>
        <h2>擅長<em>什麼</em></h2>
      </div>
      <span class="num">— 01</span>
    </div>
    <div class="expertise-grid">
      <div class="exp-tile reveal">
        <div class="exp-num">01</div>
        <h3>VI 規劃 & 主視覺</h3>
        <p>標準字、識別系統、年度主視覺、活動延伸應用。從 logo 到整套品牌資產一次到位。</p>
      </div>
      <div class="exp-tile reveal">
        <div class="exp-num">02</div>
        <h3>DM & 平面設計</h3>
        <p>DM 改版、宣傳單張、Banner、海報。專門處理資訊量大、要在小篇幅內說清楚的案子。</p>
      </div>
      <div class="exp-tile reveal">
        <div class="exp-num">03</div>
        <h3>說明書與編輯設計</h3>
        <p>長篇資訊的分層、圖示重繪、閱讀動線。讓厚手冊也能被讀完。</p>
      </div>
      <div class="exp-tile reveal">
        <div class="exp-num">04</div>
        <h3>包裝設計</h3>
        <p>從結構、平面到插畫一次完成的包裝系列。擅長處理在地品牌、文創、農特產。</p>
      </div>
      <div class="exp-tile reveal">
        <div class="exp-num">05</div>
        <h3>UI / UX 設計</h3>
        <p>訂位系統、營運後台、會員介面。不只是美，更要好用、能解決真的問題。</p>
      </div>
      <div class="exp-tile reveal">
        <div class="exp-num">06</div>
        <h3>社群內容</h3>
        <p>貼文模板系統、節慶活動圖、品牌日常內容。建一套工具讓團隊能持續產出。</p>
      </div>
    </div>
  </section>

  <section class="container track-record">
    <div class="section-head">
      <div>
        <div class="eyebrow">Numbers</div>
        <h2><em>實績</em></h2>
      </div>
      <span class="num">— 02</span>
    </div>
    <div class="stats-grid">
      <div class="stat reveal"><div class="stat-num">20<span>+</span></div><div class="stat-label">品牌識別案例</div></div>
      <div class="stat reveal"><div class="stat-num">6</div><div class="stat-label">完整包裝系列</div></div>
      <div class="stat reveal"><div class="stat-num">3</div><div class="stat-label">產品介面系統</div></div>
      <div class="stat reveal"><div class="stat-num">60<span>+</span></div><div class="stat-label">單張視覺作品</div></div>
    </div>
    <div class="client-types reveal">
      <div class="eyebrow" style="margin-bottom: 14px;">服務過的客戶類型</div>
      <p>地方社區發展協會 · 製造業集團 · 私人會員制俱樂部 · 電動車充電網營運商 · 食品與農特產品牌 · 生活風格品牌 · 文化展覽機構</p>
    </div>
  </section>

  <section class="container">
    <div class="section-head">
      <div>
        <div class="eyebrow">Work</div>
        <h2>作品<em>分類</em></h2>
      </div>
      <span class="num">— 03</span>
    </div>

    <script is:inline>
      (function () {
        const entrance = document.getElementById("entrance");
        if (!entrance) return;
        const stage = entrance.querySelector(".entrance-stage");
        const update = () => {
          const r = entrance.getBoundingClientRect();
          const scrolled = -r.top;
          const total = entrance.offsetHeight - window.innerHeight;
          const p = Math.max(0, Math.min(1, scrolled / total));
          stage.style.setProperty("--open", p.toFixed(3));
        };
        window.addEventListener("scroll", update, { passive: true });
        window.addEventListener("resize", update);
        update();
      })();
    </script>
    <div class="category-list">
      {categories.map(c => {
        const count = c.subsections ? c.subsections.reduce((n, s) => n + s.images.length, 0) : (c.images?.length ?? 0);
        return (
          <a href={`${base}/work#${c.key}`} class="category-row reveal">
            <div class="cat-info">
              <h3>{c.name}</h3>
              <p>{c.desc}</p>
            </div>
            <div class="cat-count">{count} 件 →</div>
          </a>
        );
      })}
    </div>
  </section>
</Layout>
