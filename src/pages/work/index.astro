---
import Layout from "../../layouts/Layout.astro";
import { works } from "../../data/works";
import { categories, type GalleryItem, type GalleryDemo } from "../../data/gallery";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

type Tab = {
  id: string;
  name: string;
  desc: string;
  philosophy?: string;
  catName: string;
  catTag: string;
  type: "images" | "demos" | "cases" | "mixed";
  images?: GalleryItem[];
  demos?: GalleryDemo[];
};

const tabs: Tab[] = [];
for (const c of categories) {
  if (c.subsections) {
    c.subsections.forEach((sub, i) => {
      tabs.push({
        id: `${c.key}-${i}`,
        name: sub.title,
        desc: sub.note ?? c.desc,
        philosophy: c.philosophy,
        catName: c.name,
        catTag: c.tagline,
        type: "images",
        images: sub.images,
      });
    });
  } else if (c.demos && c.images) {
    tabs.push({ id: c.key, name: c.name, desc: c.desc, philosophy: c.philosophy, catName: c.name, catTag: c.tagline, type: "mixed", demos: c.demos, images: c.images });
  } else if (c.demos) {
    tabs.push({ id: c.key, name: c.name, desc: c.desc, philosophy: c.philosophy, catName: c.name, catTag: c.tagline, type: "demos", demos: c.demos });
  } else if (c.images) {
    tabs.push({ id: c.key, name: c.name, desc: c.desc, philosophy: c.philosophy, catName: c.name, catTag: c.tagline, type: "images", images: c.images });
  }
}
tabs.push({
  id: "cases",
  name: "包裝設計",
  desc: "需要完整脈絡說明的長篇案例。",
  philosophy: "包裝設計需要從結構、平面到插畫一次完成 — 在貨架上、手中、與手機螢幕上都站得住的產品而做。\n\n擅長處理在地品牌、文創、農特產類案件，強調誠實傳達產品本身，不過度包裝成文創樣板。",
  catName: "Case Studies",
  catTag: "— Projects",
  type: "cases",
});
---
<Layout title="作品 — Alice Office">
  <section class="container hero" style="padding-bottom: 24px;">
    <div class="eyebrow">— 作品集</div>
    <h1>完整<em>作品</em></h1>
    <p class="lead">分類整理的作品集，依主題切換瀏覽。</p>
  </section>

  <div class="work-layout">
    <aside class="work-tabs-vertical" role="tablist">
      {tabs.map((t, i) => (
        <button class={`vtab ${i === 0 ? "active" : ""}`} data-tab={t.id} role="tab" aria-selected={i === 0 ? "true" : "false"}>
          <span class="vtab-num">{String(i + 1).padStart(2, "0")}</span>
          <span class="vtab-name">{t.name}</span>
        </button>
      ))}
    </aside>

    <main class="work-content">
      {tabs.map((t, i) => (
        <section class={`tab-pane ${i === 0 ? "active" : ""}`} id={t.id} role="tabpanel">
          <div class="section-head" style="padding-top: 0;">
            <div>
              <div class="eyebrow" style="margin-bottom: 10px;">{t.catTag} · {t.catName}</div>
              <h2>{t.name}</h2>
            </div>
            <span class="num">— {
              t.type === "demos" ? t.demos!.length
                : t.type === "cases" ? works.length
                : t.type === "mixed" ? (t.demos!.length + t.images!.length)
                : t.images!.length
            } 件</span>
          </div>

          {(t.type === "demos" || t.type === "mixed") && t.demos && (
            <div class="demo-grid">
              {t.demos.map((d, di) => (
                <article class="demo-card" data-img={`${t.id}-demo-${di}`}>
                  <div class="demo-frame" style={`aspect-ratio: ${d.ratio ?? "16 / 9"};`}>
                    <iframe src={d.src} loading="lazy" title={d.title} sandbox="allow-scripts allow-same-origin allow-popups"></iframe>
                  </div>
                  <div class="demo-meta">
                    <span class="tag">{d.tag}</span>
                    <h3>{d.title}</h3>
                    {d.desc && <p>{d.desc}</p>}
                  </div>
                </article>
              ))}
            </div>
          )}
          {t.type === "mixed" && t.images && (
            <div class="case-image-stack">
              {t.images.map((im, ii) => (
                <figure class="case-image" data-img={`${t.id}-img-${ii}`}>
                  <div class="frame">
                    {im.src.endsWith(".mp4") || im.src.endsWith(".webm")
                      ? <video src={im.src} autoplay loop muted playsinline></video>
                      : <img src={im.src} alt={im.caption ?? t.name} loading="lazy" />}
                  </div>
                  {im.caption && <figcaption>{im.caption}</figcaption>}
                </figure>
              ))}
            </div>
          )}
          {t.type === "cases" && (
            <div class="featured">
              {works.map((w) => (
                <a href={`${base}/work/${w.slug}`} class={`work-card ${w.span ?? ""}`}>
                  <div class="frame"><img src={w.cover} alt={w.title} loading="lazy" /></div>
                  <div class="meta">
                    <span class="tag">{w.tag}</span>
                    <span class="title">{w.title}</span>
                    <span class="year">{w.year}</span>
                  </div>
                </a>
              ))}
            </div>
          )}
          {t.type === "images" && t.images && (
            <div class="gallery-grid">
              {t.images.map((im, ii) => (
                <figure class="gallery-item" data-img={`${t.id}-img-${ii}`}>
                  <div class="frame">
                    {im.src.endsWith(".mp4") || im.src.endsWith(".webm")
                      ? <video src={im.src} autoplay loop muted playsinline></video>
                      : <img src={im.src} alt={im.caption ?? t.name} loading="lazy" />}
                  </div>
                  {im.caption && <figcaption>{im.caption}</figcaption>}
                </figure>
              ))}
            </div>
          )}
        </section>
      ))}
    </main>

    <aside class="work-philosophy">
      {/* Category-level philosophy (default per tab) */}
      {tabs.map((t, i) => (
        <article class={`phi ${i === 0 ? "active" : ""}`} data-pane={t.id}>
          <div class="phi-eyebrow">{t.catTag}</div>
          <h3 class="phi-title">作品理念</h3>
          {t.philosophy && t.philosophy.split("\n\n").map(p => <p>{p}</p>)}
          <p class="phi-desc">{t.desc}</p>
        </article>
      ))}
      {/* Per-image philosophy panes — shown when an image is clicked */}
      {tabs.map(t => (
        <>
          {t.images?.map((im, ii) => (
            <article class="phi phi-item" data-pane={`${t.id}-img-${ii}`} data-parent={t.id}>
              <button class="phi-back" type="button">← 返回 作品理念</button>
              <div class="phi-eyebrow">{t.catTag}</div>
              <h3 class="phi-title">{im.caption}</h3>
              {im.note ? im.note.split("\n\n").map(p => <p>{p}</p>) : <p class="phi-empty">這件作品的詳細思考還沒整理上來。歡迎直接<a href={`${base}/contact`}>聊聊看</a>。</p>}
            </article>
          ))}
          {t.demos?.map((d, di) => (
            <article class="phi phi-item" data-pane={`${t.id}-demo-${di}`} data-parent={t.id}>
              <button class="phi-back" type="button">← 返回 作品理念</button>
              <div class="phi-eyebrow">{t.catTag}</div>
              <h3 class="phi-title">{d.title}</h3>
              <p class="phi-tag-line">{d.tag}</p>
              {d.desc && <p>{d.desc}</p>}
            </article>
          ))}
        </>
      ))}
    </aside>
  </div>

  <script is:inline>
    (function () {
      const buttons = document.querySelectorAll(".vtab");
      const panes = document.querySelectorAll(".tab-pane");
      const phis = document.querySelectorAll(".phi");

      const showPhi = (key) => {
        phis.forEach(p => p.classList.toggle("active", p.dataset.pane === key));
      };
      const showItems = (key) => {
        document.querySelectorAll("[data-img].is-active").forEach(el => el.classList.remove("is-active"));
        const el = document.querySelector(`[data-img="${key}"]`);
        if (el) el.classList.add("is-active");
      };

      // Tab switch — also reset philosophy to category default
      buttons.forEach(btn => {
        btn.addEventListener("click", () => {
          const target = btn.getAttribute("data-tab");
          buttons.forEach(b => {
            const on = b === btn;
            b.classList.toggle("active", on);
            b.setAttribute("aria-selected", on ? "true" : "false");
          });
          panes.forEach(p => p.classList.toggle("active", p.id === target));
          showPhi(target);
          document.querySelectorAll("[data-img].is-active").forEach(el => el.classList.remove("is-active"));
        });
      });

      // Click on image / demo card → show its philosophy
      document.querySelectorAll("[data-img]").forEach(el => {
        el.addEventListener("click", (e) => {
          // don't hijack iframe inside demo-card
          if (el.classList.contains("demo-card") && e.target.closest("iframe")) return;
          // don't hijack links inside cards
          if (e.target.closest("a") && !el.contains(e.target.closest("a"))) return;
          const key = el.getAttribute("data-img");
          showPhi(key);
          showItems(key);
        });
      });

      // Back button on per-image philosophy
      document.querySelectorAll(".phi-back").forEach(btn => {
        btn.addEventListener("click", () => {
          const parent = btn.closest(".phi")?.dataset.parent;
          if (parent) {
            showPhi(parent);
            document.querySelectorAll("[data-img].is-active").forEach(el => el.classList.remove("is-active"));
          }
        });
      });

      const hash = window.location.hash.replace("#", "");
      if (hash) {
        const btn = document.querySelector(`.vtab[data-tab="${hash}"]`);
        if (btn) btn.click();
      }
    })();
  </script>
</Layout>
