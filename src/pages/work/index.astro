---
import Layout from "../../layouts/Layout.astro";
import { works } from "../../data/works";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<Layout title="作品 — Alice Office">
  <section class="container hero" style="padding-bottom: 40px;">
    <div class="eyebrow">— 作品索引</div>
    <h1>完整<em>作品集</em></h1>
    <p class="lead">橫跨品牌識別、編輯設計、包裝、與產品介面的精選案例。多數已公開發表，少數因簽約限制以代稱呈現。</p>
  </section>

  <section class="container">
    <div class="featured" style="grid-template-columns: 1fr;">
      {works.map((w) => (
        <a href={`${base}/work/${w.slug}`} class="work-card reveal">
          <div class="frame"><img src={w.cover} alt={w.title} loading="lazy" /></div>
          <div class="meta">
            <span class="tag">{w.tag}</span>
            <span class="title">{w.title}</span>
            <span class="year">{w.year}</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
