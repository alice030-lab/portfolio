---
import Layout from "../../layouts/Layout.astro";
import { works } from "../../data/works";

export function getStaticPaths() {
  return works.map(w => ({ params: { slug: w.slug }, props: { work: w } }));
}

const { work } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const i = works.findIndex(w => w.slug === work.slug);
const next = works.length > 1 ? works[(i + 1) % works.length] : null;
---
<Layout title={`${work.title} — Alice Office`} description={work.summary}>
  <article>
    <section class="container case-hero">
      <div class="eyebrow">{work.tag} — {work.year}</div>
      <h1 style="margin-top: 24px;">{work.title}</h1>
      <p class="lead" style="margin-top: 32px; max-width: 60ch;">{work.summary}</p>
      <div class="meta">
        <div><strong>客戶</strong>{work.client}</div>
        <div><strong>年份</strong>{work.year}</div>
        <div><strong>角色</strong>{work.role}</div>
        <div><strong>工作範圍</strong>{work.scope.join(" · ")}</div>
      </div>
    </section>

    <section class="container">
      <div class="full" style="margin-top: 24px;"><img src={work.cover} alt={work.title} /></div>
    </section>

    <section class="container case-body">
      {work.body.map(b => {
        if (b.type === "p") return <p>{b.text}</p>;
        if (b.type === "full") return <div class="full"><img src={b.src} alt={b.alt} loading="lazy" /></div>;
        if (b.type === "pair") return <div class="pair">{b.pair?.map(p => <img src={p.src} alt={p.alt} loading="lazy" />)}</div>;
        return null;
      })}
    </section>

    {next && (
      <section class="container">
        <a href={`${base}/work/${next.slug}`} class="work-card reveal" style="padding-top: 60px; display: block;">
          <div class="eyebrow" style="margin-bottom: 16px;">下一個案例</div>
          <h2 style="margin-bottom: 24px;">{next.title} →</h2>
          <div class="frame" style="aspect-ratio: 16 / 9;"><img src={next.cover} alt={next.title} loading="lazy" /></div>
        </a>
      </section>
    )}
  </article>
</Layout>
