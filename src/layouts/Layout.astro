---
import "../styles/global.css";
const { title = "Alice Office — 品牌與編輯設計", description = "吳芝淩的設計實踐：品牌識別、包裝、產品介面。" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const path = Astro.url.pathname.replace(base, "") || "/";
const isActive = (p: string) => path === p || (p !== "/" && path.startsWith(p));
const link = (p: string) => `${base}${p}`;
---
<!doctype html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=Fraunces:ital,opsz,wght@0,9..144,700;0,9..144,900;1,9..144,700;1,9..144,900&family=Inter:wght@400;500;700&family=Noto+Sans+TC:wght@400;500;700&family=Noto+Serif+TC:wght@400;500;700&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- Book page-flip loader — hand-drawn SVG, visible until window.load + min 1.6s -->
  <div id="book-loader" class="book-loader" aria-hidden="true">
    <svg class="book-svg" viewBox="0 0 420 300" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <!-- Hand-drawn jitter filter -->
        <filter id="rough" x="-2%" y="-2%" width="104%" height="104%">
          <feTurbulence type="fractalNoise" baseFrequency="0.02" numOctaves="2" seed="3" />
          <feDisplacementMap in="SourceGraphic" scale="1.6" />
        </filter>
      </defs>

      <g class="ink" stroke="#6B4515" fill="#FBFAF5" stroke-width="2.5"
         stroke-linecap="round" stroke-linejoin="round" filter="url(#rough)">

        <!-- LEFT BOTTOM COVER (spine slants up-right toward middle) -->
        <path d="M 40 250 Q 50 225 60 215 L 200 175 L 200 250 Q 130 258 60 256 Q 48 258 40 250 Z" />
        <!-- LEFT cover bottom edge hatching -->
        <path fill="none" d="M 60 245 L 90 240 M 70 255 L 110 248 M 95 262 L 145 252" />

        <!-- RIGHT BOTTOM COVER (with cross-hatch on outer side) -->
        <path d="M 200 175 L 380 215 Q 388 225 390 250 Q 380 258 350 256 L 200 250 Z" />
        <!-- RIGHT cover hatching (denser, like reference) -->
        <path fill="none" d="
          M 240 210 L 360 230
          M 235 220 L 365 240
          M 230 230 L 370 248
          M 225 240 L 372 254
          M 295 220 L 305 240
          M 320 215 L 330 245
          M 345 215 L 355 248" stroke-width="1.4" />

        <!-- SPINE / center binding -->
        <path fill="none" d="M 200 175 L 200 250" stroke-width="2.8" />

        <!-- FLIPPING PAGE 1 (front, lifting from spine, slight curl) -->
        <g class="fly fly-1">
          <path d="M 200 175 L 215 90 Q 250 60 295 80 L 310 175 Q 255 168 200 175 Z" />
          <path fill="none" d="M 230 110 L 270 100 M 240 130 L 280 120 M 250 150 L 285 140" stroke-width="1.4" />
        </g>

        <!-- FLIPPING PAGE 2 (back, taller arc) -->
        <g class="fly fly-2">
          <path d="M 200 175 L 245 60 Q 295 35 345 65 L 330 175 Q 270 170 200 175 Z" />
          <path fill="none" d="M 260 90 L 295 75 M 270 110 L 305 95 M 280 130 L 315 115 M 290 150 L 320 135" stroke-width="1.4" />
        </g>

        <!-- TOP fold lines (suggest pages curving) -->
        <path fill="none" d="M 200 175 L 215 92" stroke-width="1.6" />
        <path fill="none" d="M 200 175 L 245 65" stroke-width="1.6" />
      </g>
    </svg>
    <div class="book-loader-text">翻開設計師的故事…</div>
  </div>
  <script is:inline>
    (function () {
      const loader = document.getElementById("book-loader");
      if (!loader) return;
      const start = Date.now();
      const minMs = 1600;
      let hidden = false;
      const hide = () => {
        if (hidden) return;
        hidden = true;
        const elapsed = Date.now() - start;
        const wait = Math.max(0, minMs - elapsed);
        setTimeout(() => {
          loader.classList.add("is-hidden");
          setTimeout(() => loader.remove(), 700);
        }, wait);
      };
      if (document.readyState === "complete") hide();
      else window.addEventListener("load", hide, { once: true });
      // Fallback: never block more than 8 seconds even if some asset stalls
      setTimeout(hide, 8000);
    })();
  </script>

  <header class="site-header">
    <div class="inner">
      <a href={link("/")} class="brand">Alice Office<small>吳芝淩</small></a>
      <nav class="nav">
        <a href={link("/")} class={isActive("/") ? "active" : ""}>首頁</a>
        <a href={link("/work")} class={isActive("/work") ? "active" : ""}>作品</a>
        <a href={link("/about")} class={isActive("/about") ? "active" : ""}>關於</a>
        <a href={link("/pricing")} class={isActive("/pricing") ? "active" : ""}>方案</a>
        <a href={link("/contact")} class={isActive("/contact") ? "active" : ""}>聯絡</a>
      </nav>
    </div>
  </header>

  <main><slot /></main>

  <footer class="site-footer">
    <div class="inner">
      <div class="big">一起做出<br/><em style="font-style:italic;color:#6b6b6b">值得細看的設計。</em></div>
      <div class="meta">
        <span>© {new Date().getFullYear()} Alice Office</span>
        <span>台北 · 台灣</span>
        <a href="mailto:hello@aliceoffice.studio">hello@aliceoffice.studio</a>
      </div>
    </div>
  </footer>

  <script>
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add("in"); io.unobserve(e.target); } });
    }, { threshold: 0, rootMargin: "0px 0px -10% 0px" });
    document.querySelectorAll(".reveal").forEach(el => io.observe(el));
  </script>
</body>
</html>
